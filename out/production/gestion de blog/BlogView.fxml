<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TitledPane?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="660.0" prefWidth="798.0" style="-fx-background-color: #FFB6C1;" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.esprit.Controller.BlogController">
    <children>
        <!-- Titre du Blog -->
        <Label layoutX="120.0" layoutY="162.0" text="Titre:" textFill="#4800ff" />
        <TextField fx:id="tfTitre" layoutX="237.0" layoutY="158.0" prefWidth="200.0" />

        <!-- Contenu du Blog -->
        <Label layoutX="98.0" layoutY="330.0" text="description : " textFill="#0900ff" wrapText="true" />
        <TextField fx:id="tfContenu" layoutX="237.0" layoutY="200.0" prefWidth="200.0" />

        <!-- Auteur du Blog -->
        <Label layoutX="114.0" layoutY="204.0" text="Cathegorie:" textFill="#0900ff" />

        <!-- Date du Blog -->
        <Label layoutX="247.0" layoutY="485.0" text="Date:" textFill="#2b00ff" />
        <DatePicker fx:id="dpDate" layoutX="300.0" layoutY="481.0" />

        <!-- Bouton pour ajouter le blog -->
        <Button layoutX="355.0" layoutY="544.0" onAction="#ajouterBlog" text="Publier" />
      <TextArea layoutX="224.0" layoutY="265.0" prefHeight="146.0" prefWidth="502.0" />
      <ImageView fitHeight="133.0" fitWidth="149.0" layoutX="321.0" layoutY="5.0" pickOnBounds="true" preserveRatio="true">

      </ImageView>
      <TitledPane layoutX="286.0" layoutY="424.0" text="Disponibilité">
         <content>
            <ImageView fitWidth="200.0" pickOnBounds="true" preserveRatio="true" />
         </content>
      </TitledPane>
      <Label layoutX="99.0" layoutY="429.0" text=" Etat : " textFill="#2200ff" wrapText="true" />
    </children>
</AnchorPane>
